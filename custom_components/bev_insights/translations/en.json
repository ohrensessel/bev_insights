  "options": {
    "step": {
      "init": {
        "title": "BEV Insights options",
        "description": "Tune how strictly the measured-range sensors filter noisy data, and how far back the rolling-window sensors look. Defaults are good for typical use; only change them if you have a specific reason.",
        "data": {
          "min_measured_range_km": "Minimum distance after charging (km)",
          "min_measured_range_soc_percent": "Minimum SoC consumed after charging (%)",
          "history_days": "History retention window (days)",
          "standstill_movement_threshold_km": "Parked detection threshold (km)",
          "low_soc_threshold_percent": "Low SoC threshold (%)"
        },
        "data_description": {
          "min_measured_range_km": "The measured range and measured efficiency sensors stay unavailable until at least this much distance has been driven since the last charge end. Default 20 km.",
          "min_measured_range_soc_percent": "And until at least this much SoC has been consumed. Default 2 %. Both floors apply; SoC quantization (~1% on most BEVs) dominates measurement error below them.",
          "history_days": "How many days of SoC and odometer samples to retain on disk for the rolling-window sensors. Default 8 (one day past the 7-day window so there's always a pre-cutoff anchor). Going below 7 will leave the rolling-7-day sensors permanently in partial-data mode.",
          "standstill_movement_threshold_km": "A SoC drop interval is counted as standstill (vampire drain) only if the odometer advanced by less than this threshold. Default 0.1 km. Raise to 1.0 km if your integration reports mileage in whole kilometres and you see standstill drain misclassified as driving.",
          "low_soc_threshold_percent": "The 'days to low SoC' sensor estimates when SoC will drop to this level. Default 20 %. Lower values give a tighter estimate before the battery is fully depleted; higher values give more warning time."
        }
      }
    }
  },
  "issues": {
    "v1_capacity_migration": {
      "title": "BEV Insights: reconfigure required for \"{title}\"",
      "description": "Your BEV Insights configuration uses the pre-v0.7 actual-capacity format (was a fixed number; now an entity reference). The previous value was **{old_kwh} kWh** — create an `input_number` helper with that value in **Settings → Devices & services → Helpers**, then open the BEV Insights integration card and click **Configure** to point it at the new helper. This repair entry will clear automatically once setup succeeds."
    },
    "missing_source_entity": {
      "title": "BEV Insights: source entity `{entity_id}` is no longer available",
      "description": "The entity **{entity_id}** is configured as the **{conf_key}** for the BEV Insights integration **\"{title}\"** but Home Assistant doesn't know it. Common causes:\n\n- The upstream integration that exposed it was uninstalled or hasn't loaded.\n- The entity was renamed.\n- You restored from a backup without the upstream integration.\n\nDerived sensors that depend on this entity will be unavailable. Open the BEV Insights integration card and click **Configure** to point it at a replacement entity. This issue clears automatically once the entity is back."
    },
    "value_capacity_out_of_range": {
      "title": "BEV Insights: actual capacity `{entity_id}` reports an implausible value",
      "description": "The actual-capacity helper **{entity_id}** for **\"{title}\"** is **{value} kWh** — outside the plausible {min_kwh}–{max_kwh} kWh range for a BEV. Common causes:\n\n- A typo on the `input_number` helper (e.g. `770` instead of `77`).\n- The wrong entity is selected — pointing at SoC % or another non-capacity sensor.\n\nThe `actual capacity` variant of every efficiency, range and energy sensor is computed from this value, so wrong values silently degrade those sensors. Update the helper or reconfigure the integration to point at the correct entity. This issue clears automatically once the value is back in range."
    },
    "value_soc_out_of_range": {
      "title": "BEV Insights: SoC source `{entity_id}` reports {value} %",
      "description": "The SoC source **{entity_id}** for **\"{title}\"** is reporting **{value} %** — outside the valid 0–100 % range. This usually indicates a bug in the upstream integration. The integration clamps the value before using it, so derived sensors keep working, but the underlying data is wrong and should be investigated. This issue clears automatically once the reported value is back in range."
    },
    "value_mileage_went_backwards": {
      "title": "BEV Insights: odometer `{entity_id}` went backwards",
      "description": "The mileage source **{entity_id}** for **\"{title}\"** dropped from **{previous_km} km** to **{current_km} km**. Distance-based sensors clamp negative deltas to zero so they don't report nonsense, but the underlying data is wrong — usually a bug in the upstream integration, an entity rename that re-used the same ID, or a manual edit to the odometer. This issue clears automatically once the odometer climbs back past the previous peak."
    },
    "value_unknown_distance_unit": {
      "title": "BEV Insights: `{entity_id}` reports an unknown unit (`{unit}`)",
      "description": "The **{conf_key}** entity **{entity_id}** for **\"{title}\"** reports its value in **`{unit}`**, which BEV Insights doesn't know how to convert to kilometres. It falls back to treating the value as kilometres, which is almost certainly wrong if the entity is actually using miles, metres or something else. Fix the upstream entity's `unit_of_measurement` attribute, or pick a different source entity from **Configure**. This issue clears automatically once the unit changes to a recognised one (`km`, `mi`, `m`)."
    }
  },
