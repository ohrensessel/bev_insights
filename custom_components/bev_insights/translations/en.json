  "options": {
    "step": {
      "init": {
        "title": "BEV Insights options",
        "description": "Tune how strictly the measured-range sensors filter noisy data, and how far back the rolling-window sensors look. Defaults are good for typical use; only change them if you have a specific reason.",
        "data": {
          "min_measured_range_km": "Minimum distance after charging (km)",
          "min_measured_range_soc_percent": "Minimum SoC consumed after charging (%)",
          "history_days": "History retention window (days)",
          "standstill_movement_threshold_km": "Parked detection threshold (km)"
        },
        "data_description": {
          "min_measured_range_km": "The measured range and measured efficiency sensors stay unavailable until at least this much distance has been driven since the last charge end. Default 20 km.",
          "min_measured_range_soc_percent": "And until at least this much SoC has been consumed. Default 2 %. Both floors apply; SoC quantization (~1% on most BEVs) dominates measurement error below them.",
          "history_days": "How many days of SoC and odometer samples to retain on disk for the rolling-window sensors. Default 8 (one day past the 7-day window so there's always a pre-cutoff anchor). Going below 7 will leave the rolling-7-day sensors permanently in partial-data mode.",
          "standstill_movement_threshold_km": "A SoC drop interval is counted as standstill (vampire drain) only if the odometer advanced by less than this threshold. Default 0.1 km. Raise to 1.0 km if your integration reports mileage in whole kilometres and you see standstill drain misclassified as driving."
        }
      }
    }
  },
  "issues": {
    "v1_capacity_migration": {
      "title": "BEV Insights: reconfigure required for \"{title}\"",
      "description": "Your BEV Insights configuration uses the pre-v0.7 actual-capacity format (was a fixed number; now an entity reference). The previous value was **{old_kwh} kWh** — create an `input_number` helper with that value in **Settings → Devices & services → Helpers**, then open the BEV Insights integration card and click **Configure** to point it at the new helper. This repair entry will clear automatically once setup succeeds."
    }
